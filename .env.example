# ═══════════════════════════════════════════════════════════════════════
# EduPath Optimizer - Environment Configuration Template
# Copy to .env and fill in actual values for your deployment
# ═══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────
APP_NAME=EduPath Optimizer
APP_VERSION=2.0.0
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=false
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─────────────────────────────────────────────────────────────
# SERVER SETTINGS
# ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─────────────────────────────────────────────────────────────
# DATABASE SETTINGS (MongoDB)
# ─────────────────────────────────────────────────────────────
# Local Development Example:
# MONGODB_URI=mongodb://localhost:27017
# 
# MongoDB Atlas Cloud (Recommended):
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority
#
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=edupath_optimizer
MONGODB_TIMEOUT=30000

# ─────────────────────────────────────────────────────────────
# SECURITY SETTINGS
# ─────────────────────────────────────────────────────────────
# CRITICAL: Generate strong secret key!
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Bash: openssl rand -base64 32
#
SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────
# UNIVERSITY SETTINGS (Multi-Campus Support)
# ─────────────────────────────────────────────────────────────
UNIVERSITY_NAME=Your University Name
UNIVERSITY_ID=UNIV_001
ENABLE_MULTI_CAMPUS=true
DEFAULT_CAMPUS_ID=CAMPUS_MAIN
ENABLE_MULTI_DEPARTMENT=true

# ─────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────
ENABLE_PHASE_1=true
ENABLE_PHASE_2=true
ENABLE_PHASE_3=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# ─────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (Optional)
# ─────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@your-university.edu

# ─────────────────────────────────────────────────────────────
# LDAP/ACTIVE DIRECTORY (Optional - for university SSO)
# ─────────────────────────────────────────────────────────────
ENABLE_LDAP=false
LDAP_SERVER=ldap.university.edu
LDAP_PORT=389
LDAP_BASE_DN=dc=university,dc=edu
LDAP_BIND_DN=cn=admin,dc=university,dc=edu
LDAP_BIND_PASSWORD=admin-password

# ─────────────────────────────────────────────────────────────
# BACKUP & RECOVERY
# ─────────────────────────────────────────────────────────────
ENABLE_BACKUPS=true
BACKUP_FREQUENCY=daily  # Options: hourly, daily, weekly
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/backups

# ─────────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ─────────────────────────────────────────────────────────────
ENABLE_METRICS=true
ENABLE_SENTRY=false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456
SENTRY_ENVIRONMENT=production
